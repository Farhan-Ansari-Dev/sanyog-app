{
  "expo": {
    "name": "BSwift by Sanyog",
    "slug": "sanyog-conformity-solutions",
    "version": "1.0.0",
    "scheme": "sanyog",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sanyog.conformity",
      "buildNumber": "1"
    },
    "android": {
      "package": "com.sanyog.conformity",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "48ee77d4-664b-4361-ba43-0c40a1a80135"
      }
    }
  }
}
